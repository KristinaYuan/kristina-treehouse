---
// BaseLayout.astro — HTML shell used by all pages.
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/theme.css';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');

export interface Props {
  title?: string;
  description?: string;
  /** Set to true for narrow (800px) article layout */
  narrow?: boolean;
}

const {
  title,
  description = 'A little library in the trees. Notes, stories, ideas, and quiet moments.',
  narrow = false,
} = Astro.props;

const fullTitle = title
  ? `${title} — Kristina's Treehouse`
  : "Kristina's Treehouse";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <title>{fullTitle}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;1,14..32,400&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
  </head>

  <body>
    <Header />

    <main class:list={['container', narrow ? 'container--narrow' : '']}>
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    margin-top: var(--header-height);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-2xl);
    min-height: calc(100vh - var(--header-height));
  }
</style>
