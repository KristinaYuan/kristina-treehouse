---
// BaseLayout.astro — HTML shell used by all pages.
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/theme.css';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');

export interface Props {
  title?: string;
  description?: string;
  /** Set to true for narrow (800px) article layout */
  narrow?: boolean;
}

const {
  title,
  description = 'A little library in the trees. Notes, stories, ideas, and quiet moments.',
  narrow = false,
} = Astro.props;

const fullTitle = title
  ? `${title} — Kristina's Treehouse`
  : "Kristina's Treehouse";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <title>{fullTitle}</title>

    <ViewTransitions />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />

    <!-- Open Graph / Social preview -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${base}/apple-touch-icon.png`} />
    <meta property="og:image:width" content="180" />
    <meta property="og:image:height" content="180" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${base}/apple-touch-icon.png`} />

    <!-- Blocking script: set theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        const html = document.documentElement;
        const stored = localStorage.getItem('theme');
        const mq = window.matchMedia('(prefers-color-scheme: dark)');

        function applyTheme() {
          const mode = localStorage.getItem('theme');
          if (mode === 'light') {
            html.removeAttribute('data-theme');
            html.setAttribute('data-theme-state', 'light');
          } else if (mode === 'dark') {
            html.setAttribute('data-theme', 'dark');
            html.setAttribute('data-theme-state', 'dark');
          } else {
            // Auto: follow system
            html.removeAttribute('data-theme-state');
            if (mq.matches) {
              html.setAttribute('data-theme', 'dark');
            } else {
              html.removeAttribute('data-theme');
            }
          }
        }

        applyTheme();

        // Listen for system theme changes (triggers when device schedule changes)
        mq.addEventListener('change', function () {
          if (!localStorage.getItem('theme')) {
            // Only react when in auto mode
            if (mq.matches) {
              html.setAttribute('data-theme', 'dark');
            } else {
              html.removeAttribute('data-theme');
            }
          }
        });
      })();
    </script>
  </head>

  <body>
    <Header />

    <div class="main-area">
      <main class:list={['container', narrow ? 'container--narrow' : '']}>
        <slot />
      </main>

      <!-- Back to top -->
      <button class="back-to-top" id="back-to-top" aria-label="Back to top">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 15l-6-6-6 6"/>
        </svg>
      </button>
    </div>

    <Footer />
  </body>
</html>

<style>
  .main-area {
    position: relative;
  }

  main {
    margin-top: var(--header-height);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-2xl);
    min-height: calc(100vh - var(--header-height));
  }

  /* Back to top button — positioned to the right of content, above footer */
  .back-to-top {
    position: fixed;
    bottom: 13rem;
    z-index: 40;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 1px solid var(--color-divider);
    border-radius: 50%;
    color: var(--color-text-muted);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity var(--transition-normal), visibility var(--transition-normal), transform var(--transition-normal), color var(--transition-fast), border-color var(--transition-fast);
    pointer-events: none;
    /* Align with right edge of content, with a gap */
    right: calc(max(var(--space-sm), (100vw - var(--max-width-home)) / 2 - 2.5rem - var(--space-sm)));
  }

  .back-to-top--visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    color: var(--color-accent-hover);
    border-color: var(--color-accent);
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    let ticking = false;

    const toggle = () => {
      btn.classList.toggle('back-to-top--visible', window.scrollY > 300);
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(toggle);
        ticking = true;
      }
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Theme toggle — cycles: light → dark → auto → light
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    const mq = window.matchMedia('(prefers-color-scheme: dark)');

    function setButtonState(mode) {
      themeToggle.classList.remove('theme-toggle--light', 'theme-toggle--dark');
      if (mode === 'light') themeToggle.classList.add('theme-toggle--light');
      if (mode === 'dark') themeToggle.classList.add('theme-toggle--dark');
    }

    // Init button state
    setButtonState(localStorage.getItem('theme'));

    themeToggle.addEventListener('click', () => {
      const html = document.documentElement;
      const current = localStorage.getItem('theme');

      if (!current || current === 'auto') {
        // Auto → Light
        localStorage.setItem('theme', 'light');
        html.removeAttribute('data-theme');
        html.setAttribute('data-theme-state', 'light');
        setButtonState('light');
      } else if (current === 'light') {
        // Light → Dark
        localStorage.setItem('theme', 'dark');
        html.setAttribute('data-theme', 'dark');
        html.setAttribute('data-theme-state', 'dark');
        setButtonState('dark');
      } else {
        // Dark → Auto
        localStorage.removeItem('theme');
        html.removeAttribute('data-theme-state');
        if (mq.matches) {
          html.setAttribute('data-theme', 'dark');
        } else {
          html.removeAttribute('data-theme');
        }
        setButtonState(null);
      }
    });
  }
</script>
