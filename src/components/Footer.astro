---
// Footer.astro — Minimal footer with contact icons.
import ContactSection from './ContactSection.astro';
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__text">
      Maybe it's not about happy ending. Maybe it's about the story.
    </p>

    <ContactSection />

    <p class="footer__copy">
      &copy; {new Date().getFullYear()} Kristina's Treehouse
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-divider);
    padding: var(--space-md) 0;
  }

  .footer__inner {
    max-width: var(--max-width-home);
    margin: 0 auto;
    padding: 0 var(--space-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    text-align: center;
  }

  .footer__text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
