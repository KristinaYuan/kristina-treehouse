---
// EducationSection.astro — Education history on the homepage.
// Data is loaded from content/profile.json.

import profileData from '../../content/profile.json';

interface EducationEntry {
  school: string;
  degree: string;
  years: string;
  description?: string;
}

interface ProfileData {
  education: EducationEntry[];
}

const data = profileData as ProfileData;
const entries = data.education ?? [];
---

{entries.length > 0 && (
  <section class="education" aria-label="Education">
    <h2 class="education__heading">Education</h2>

    <ul class="education__list">
      {entries.map((entry) => (
        <li class="education__item">
          <div class="education__item-head">
            <h3 class="education__school">{entry.school}</h3>
            <span class="education__years">{entry.years}</span>
          </div>
          <p class="education__degree">{entry.degree}</p>
          {entry.description && (
            <p class="education__desc">{entry.description}</p>
          )}
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .education {
    margin-bottom: var(--space-xl);
  }

  .education__heading {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    margin-bottom: var(--space-md);
  }

  .education__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .education__item {
    margin: 0;
    padding: 0;
  }

  .education__item-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .education__school {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 0;
  }

  .education__years {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .education__degree {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: var(--space-2xs) 0 0;
  }

  .education__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: var(--space-2xs) 0 0;
    line-height: var(--leading-snug);
  }
</style>
