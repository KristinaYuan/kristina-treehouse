---
// ContactSection.astro — Minimal contact icons in the footer.
// Data is loaded from content/profile.json. Edit that file to change contacts.
// All icons copy their value to clipboard on click.

import profileData from '../../content/profile.json';

interface ContactEntry {
  label: string;
  value: string;
  href?: string;
  icon: string;
}

interface ProfileData {
  contact: ContactEntry[];
}

const data = profileData as ProfileData;
const contacts: ContactEntry[] = (data.contact ?? []).filter((c) => {
  return ['mail', 'email', 'github', 'twitter', 'wechat', 'phone'].includes(c.icon);
});

function isLink(c: ContactEntry): boolean {
  // All contact icons now copy to clipboard
  return false;
}
---

<div class="contact-icons" aria-label="Contact">
  {contacts.map((c) => {
    const iconSvg = (() => {
      if (c.icon === 'email' || c.icon === 'mail') {
        return (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        );
      }
      if (c.icon === 'github') {
        return (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
        );
      }
      if (c.icon === 'twitter') {
        return (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4l11.733 16h4.267l-11.733 -16z"/>
            <path d="M4 20l6.768 -6.768m2.46 -2.46L20 4"/>
          </svg>
        );
      }
      if (c.icon === 'wechat') {
        return (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
        );
      }
      if (c.icon === 'phone') {
        return (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        );
      }
      return null;
    })();

    if (isLink(c) && c.href) {
      return (
        <a
          href={c.href}
          class="contact-icons__btn"
          aria-label={`${c.label}: ${c.value}`}
        >
          {iconSvg}
        </a>
      );
    }

    return (
      <button
        class="contact-icons__btn"
        aria-label={`Copy ${c.label}: ${c.value}`}
        data-copy={c.value}
        data-label={c.label}
      >
        {iconSvg}
      </button>
    );
  })}
</div>

<script>
  document.querySelectorAll('.contact-icons__btn[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const value = btn.getAttribute('data-copy');
      const label = btn.getAttribute('data-label');
      if (!value) return;

      try {
        await navigator.clipboard.writeText(value);
        const tooltip = document.createElement('span');
        tooltip.className = 'contact-icons__tooltip';
        tooltip.textContent = `Copied ${label}!`;
        btn.appendChild(tooltip);
        setTimeout(() => tooltip.remove(), 1500);
      } catch {
        // Clipboard failed — silently ignore
      }
    });
  });
</script>

<style>
  .contact-icons {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .contact-icons__btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: none;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .contact-icons__btn:hover {
    color: var(--color-accent-hover);
    background: var(--color-accent-light);
  }

  .contact-icons__tooltip {
    position: absolute;
    top: -2.25rem;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    background: var(--color-bg);
    border: 1px solid var(--color-divider);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-md);
    pointer-events: none;
    animation: tooltip-in 0.2s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  @keyframes tooltip-in {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }
</style>
