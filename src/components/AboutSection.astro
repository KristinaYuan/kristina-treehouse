---
// AboutSection.astro — Brief self-introduction on the homepage.
// Data is loaded from content/profile.json for easy editing.

import profileData from '../../content/profile.json';

interface ProfileData {
  about: {
    heading: string;
    body: string;
    avatar: string | null;
  };
}

const data = profileData as ProfileData;

// Split body into paragraphs
const paragraphs = data.about.body
  .split('\n\n')
  .filter((p: string) => p.trim().length > 0);
---

{paragraphs.length > 0 && (
  <section class="about" aria-label={data.about.heading}>
    <h2 class="about__heading">{data.about.heading}</h2>
    <div class="about__body">
      {paragraphs.map((paragraph: string) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </section>
)}

<style>
  .about {
    margin-bottom: var(--space-xl);
  }

  .about__heading {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    margin-bottom: var(--space-md);
  }

  .about__body {
    max-width: 600px;
  }

  .about__body p {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .about__body p:last-child {
    margin-bottom: 0;
  }
</style>
