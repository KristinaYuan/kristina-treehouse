---
// AboutSection.astro — Brief self-introduction on the homepage.
// Data is loaded from content/profile.json for easy editing.

import profileData from '../../content/profile.json';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');

interface ProfileData {
  about: {
    heading: string;
    body: string;
    avatar: string | null;
  };
}

const data = profileData as ProfileData;

// Split body into paragraphs
const paragraphs = data.about.body
  .split('\n\n')
  .filter((p: string) => p.trim().length > 0);

const hasAvatar = data.about.avatar && data.about.avatar.trim().length > 0;
const avatarPath = hasAvatar ? data.about.avatar!.trim().replace(/^\/+/, '') : '';
const avatarSrc = hasAvatar ? `${base}/${avatarPath}` : null;
---

{paragraphs.length > 0 && (
  <section class="about" aria-label={data.about.heading}>
    <h2 class="about__heading">{data.about.heading}</h2>

    <div class="about__layout">
      <div class="about__body">
        {paragraphs.map((paragraph: string) => (
          <p>{paragraph}</p>
        ))}
      </div>

      {avatarSrc && (
        <div class="about__avatar">
          <img
            src={avatarSrc}
            alt="Kristina's avatar"
            class="about__avatar-img"
            width="180"
            height="180"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </section>
)}

<style>
  .about {
    margin-bottom: var(--space-xl);
  }

  .about__heading {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    margin-bottom: var(--space-md);
  }

  .about__layout {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  .about__body {
    flex: 1;
    min-width: 0;
  }

  .about__body p {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .about__body p:last-child {
    margin-bottom: 0;
  }

  .about__avatar {
    flex-shrink: 0;
  }

  .about__avatar-img {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-divider);
  }

  @media (max-width: 600px) {
    .about__layout {
      flex-direction: column-reverse;
      align-items: center;
      gap: var(--space-md);
    }

    .about__avatar-img {
      width: 150px;
      height: 150px;
    }
  }
</style>
