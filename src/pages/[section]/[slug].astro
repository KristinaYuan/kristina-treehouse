---
// [section]/[slug].astro — Individual article page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  VALID_SECTIONS,
  getSectionMeta,
  getArticle,
  getAllArticles,
  getSectionArticles,
  formatDate,
} from '../../utils/content';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');

export function getStaticPaths() {
  const paths: { params: { section: string; slug: string } }[] = [];

  const modules = import.meta.glob<{
    frontmatter: { title: string; date: string };
  }>('/content/**/*.md', { eager: true });

  for (const [path] of Object.entries(modules)) {
    const match = path.match(/^\/content\/([^/]+)\/([^/]+)\.md$/);
    if (match && VALID_SECTIONS.has(match[1])) {
      paths.push({ params: { section: match[1], slug: match[2] } });
    }
  }

  return paths;
}

const { section, slug } = Astro.params;

const meta = getSectionMeta(section!);
if (!meta) {
  return Astro.redirect(base || '/');
}

const article = getArticle(section!, slug!);
if (!article) {
  return Astro.redirect(`${base}/${section}`);
}

const { frontmatter, Content } = article;

// Compute prev/next for both modes at build time.
// Section mode: within the current section only.
const sectionSiblings = getSectionArticles(section!);
const sectionIndex = sectionSiblings.findIndex(
  (a) => a.section === section && a.slug === slug
);
const sectionPrev = sectionIndex > 0 ? sectionSiblings[sectionIndex - 1] : null;
const sectionNext = sectionIndex < sectionSiblings.length - 1 ? sectionSiblings[sectionIndex + 1] : null;

// Archive mode: across all sections, sorted by date.
const allSiblings = getAllArticles();
const allIndex = allSiblings.findIndex(
  (a) => a.section === section && a.slug === slug
);
const archivePrev = allIndex > 0 ? allSiblings[allIndex - 1] : null;
const archiveNext = allIndex < allSiblings.length - 1 ? allSiblings[allIndex + 1] : null;

// Embed archive-mode nav data for client-side swap.
const archiveNavData = {
  backHref: `${base}/archive`,
  backLabel: 'Archive',
  prev: archivePrev ? {
    href: `${base}/${archivePrev.section}/${archivePrev.slug}?from=archive`,
    title: archivePrev.frontmatter.title,
  } : null,
  next: archiveNext ? {
    href: `${base}/${archiveNext.section}/${archiveNext.slug}?from=archive`,
    title: archiveNext.frontmatter.title,
  } : null,
};
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} narrow>
  <article class="article">
    <header class="article__header">
      <a href={`${base}/${section}`} class="article__back" id="article-back">
        &larr; {meta.label}
      </a>

      <h1 class="article__title">{frontmatter.title}</h1>

      <div class="article__meta">
        <time datetime={frontmatter.date}>
          Published {formatDate(frontmatter.date)}
        </time>

        {frontmatter.updated && frontmatter.updated !== frontmatter.date && (
          <span class="article__updated">
            &middot; Updated {formatDate(frontmatter.updated!)}
          </span>
        )}

        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <span class="article__tags">
            {frontmatter.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        )}
      </div>
    </header>

    <div class="article__content">
      <Content />
    </div>

    <!-- Prev / Next navigation (always rendered so JS can populate for archive mode) -->
    <nav class="article-nav" id="article-nav" aria-label="Previous and next articles">
      {(sectionPrev || sectionNext) && (
        <div class="article-nav__inner">
          {sectionPrev ? (
            <a
              href={`${base}/${sectionPrev.section}/${sectionPrev.slug}`}
              class="article-nav__link article-nav__link--prev"
            >
              <span class="article-nav__direction">&larr; Previous</span>
              <span class="article-nav__title">{sectionPrev.frontmatter.title}</span>
            </a>
          ) : (
            <span class="article-nav__link--placeholder" />
          )}

          {sectionNext ? (
            <a
              href={`${base}/${sectionNext.section}/${sectionNext.slug}`}
              class="article-nav__link article-nav__link--next"
            >
              <span class="article-nav__direction">Next &rarr;</span>
              <span class="article-nav__title">{sectionNext.frontmatter.title}</span>
            </a>
          ) : (
            <span class="article-nav__link--placeholder" />
          )}
        </div>
    )}
      </nav>
  </article>
</BaseLayout>

<!-- Archive-mode nav data for client-side swap (data attrs so Astro evaluates expressions) -->
<div
  id="archive-nav-data"
  data-back-href={archiveNavData.backHref}
  data-back-label={archiveNavData.backLabel}
  data-prev-href={archiveNavData.prev?.href ?? ''}
  data-prev-title={archiveNavData.prev?.title ?? ''}
  data-next-href={archiveNavData.next?.href ?? ''}
  data-next-title={archiveNavData.next?.title ?? ''}
  hidden
></div>

<script>
  function initArchiveMode() {
    if (new URLSearchParams(window.location.search).get('from') !== 'archive') return;

    const dataEl = document.getElementById('archive-nav-data');
    if (!dataEl) return;
    const d = dataEl.dataset;

    // Swap back link
    const back = document.getElementById('article-back');
    if (back && d.backHref) {
      back.href = d.backHref;
      back.textContent = '← ' + d.backLabel;
    }

    // Rebuild prev/next nav
    const nav = document.getElementById('article-nav');
    if (!nav || (!d.prevHref && !d.nextHref)) {
      if (nav) nav.hidden = true;
      return;
    }
    nav.hidden = false;

    const makeLink = (href, title, direction, arrow) => {
      if (!href) return '<span class="article-nav__link--placeholder"></span>';
      const cls = direction === 'prev' ? 'article-nav__link article-nav__link--prev' : 'article-nav__link article-nav__link--next';
      return `<a href="${href}" class="${cls}"><span class="article-nav__direction">${arrow}</span><span class="article-nav__title">${title}</span></a>`;
    };

    nav.innerHTML = `<div class="article-nav__inner">${
      makeLink(d.prevHref, d.prevTitle, 'prev', '← Previous') +
      makeLink(d.nextHref, d.nextTitle, 'next', 'Next →')
    }</div>`;
  }

  document.addEventListener('astro:page-load', initArchiveMode);
  initArchiveMode();
</script>

<style>
  .article {
    max-width: var(--max-width-article);
  }

  .article__header {
    margin-bottom: var(--space-lg);
  }

  .article__back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: color var(--transition-fast);
  }

  .article__back:hover {
    color: var(--color-accent);
  }

  .article__title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 500;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-sm);
  }

  .article__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .article__updated {
    color: var(--color-text-muted);
  }

  .article__tags {
    display: flex;
    gap: 0.35rem;
    margin-left: var(--space-xs);
  }

  .tag {
    display: inline-block;
    padding: 0.1em 0.5em;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-accent-subtle);
    border-radius: var(--radius-sm);
  }

  .article__content {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .article__content :global(h1),
  .article__content :global(h2),
  .article__content :global(h3) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .article__content :global(p) {
    margin-bottom: var(--space-sm);
  }

  .article__content :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--color-divider);
  }

  .article__content :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  /* Prev / Next navigation — :global() so JS-generated links in archive mode also get styled */
  .article-nav {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-divider);
  }

  .article-nav :global(.article-nav__inner) {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .article-nav :global(.article-nav__link) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-md);
    text-decoration: none;
    border: 1px solid var(--color-divider);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast), border-color var(--transition-fast);
    flex: 0 1 48%;
    min-width: 0;
  }

  .article-nav :global(.article-nav__link):hover {
    background: var(--color-accent-subtle);
    border-color: var(--color-accent);
  }

  .article-nav :global(.article-nav__link--prev) {
    align-items: flex-start;
    text-align: left;
  }

  .article-nav :global(.article-nav__link--next) {
    align-items: flex-end;
    text-align: right;
  }

  .article-nav :global(.article-nav__direction) {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .article-nav :global(.article-nav__title) {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  /* Empty placeholder so flex alignment holds when one side is missing */
  .article-nav :global(.article-nav__link--placeholder) {
    flex: 0 1 48%;
    min-width: 0;
  }

  @media (max-width: 500px) {
    .article-nav :global(.article-nav__inner) {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .article-nav :global(.article-nav__link) {
      flex: 1 1 auto;
    }

    .article-nav :global(.article-nav__link--next) {
      align-items: flex-start;
      text-align: left;
    }

    .article-nav :global(.article-nav__link--placeholder) {
      display: none;
    }
  }
</style>
